#!/bin/sh
# ============================================================================
# /etc/uci-defaults/994_set_apk_repos
# ImmortalWrt 25.12+ (apk 3.x) 首次启动软件源配置
#
# 官方依据：
#   - ImmortalWrt imm_init 机制：system.@imm_init[0].apk_mirror
#   - USTC 镜像帮助：https://mirrors.ustc.edu.cn/help/immortalwrt.html
#
# ⚠️ 注意：此脚本在首次启动时由 /etc/init.d/boot 自动执行
#          执行成功后会自动删除（uci-defaults 标准行为）
# ============================================================================

MIRROR_URL="https://mirrors.ustc.edu.cn/immortalwrt"
DISTFEEDS="/etc/apk/repositories.d/distfeeds.list"
TMP_FEEDS="/tmp/distfeeds.list.new"

# ---- 工具函数 ----
log() { logger -t "apk-mirror" "$1"; echo "[apk-mirror] $1"; }

# ---- 1. UCI 持久化配置 (sysupgrade 后可保留) ----
if uci show system.@imm_init[0] >/dev/null 2>&1; then
    uci set system.@imm_init[0].apk_mirror="${MIRROR_URL}"
    uci commit system
    log "UCI imm_init.apk_mirror = ${MIRROR_URL}"
else
    log "⚠️ imm_init 节不存在，跳过 UCI 配置"
fi

# ---- 2. 构建新的 distfeeds.list ----
if [ ! -f "${DISTFEEDS}" ]; then
    log "⚠️ ${DISTFEEDS} 不存在，跳过"
    return 0 2>/dev/null || exit 0
fi

cp "${DISTFEEDS}" "${DISTFEEDS}.bak"
> "${TMP_FEEDS}"

# 定义所有已知的 ImmortalWrt 镜像前缀（含官方源）
OLD_MIRRORS="https://downloads.immortalwrt.org|https://mirrors.vsean.net/openwrt|https://mirrors.tuna.tsinghua.edu.cn/immortalwrt|https://mirror.nju.edu.cn/immortalwrt|https://mirrors.sustech.edu.cn/immortalwrt"

while IFS= read -r line; do
    # 跳过空行和注释行，原样保留
    case "$line" in
        ""|\#*) echo "$line" >> "${TMP_FEEDS}"; continue ;;
    esac

    # ---- 2a. 替换 ImmortalWrt 镜像源 ----
    new_line=$(echo "$line" | sed -E "s|(${OLD_MIRRORS})|${MIRROR_URL}|g")

    # ---- 2b. 跳过已知不可用的 feed ----
    # istoreos: iStoreOS 兼容源，ImmortalWrt 中使用会报错
    case "$new_line" in
        *istoreos*)
            log "🚫 跳过: iStoreOS 源 (ImmortalWrt 不兼容)"
            echo "# [disabled] ${new_line}" >> "${TMP_FEEDS}"
            continue
            ;;
    esac

    # openwrt_packages: ImmortalWrt 官方未构建此 feed (实测 404)
    # 仅跳过 ImmortalWrt 域名下的 openwrt_packages（其他源的可能可用）
    case "$new_line" in
        *immortalwrt*openwrt_packages*)
            log "🚫 跳过: openwrt_packages (ImmortalWrt 无此 feed)"
            echo "# [disabled] ${new_line}" >> "${TMP_FEEDS}"
            continue
            ;;
        *immortalwrt*/video/*)
            log "🚫 跳过: video (ImmortalWrt 无此 feed)"
            echo "# [disabled] ${new_line}" >> "${TMP_FEEDS}"
            continue
            ;;
    esac

    echo "$new_line" >> "${TMP_FEEDS}"
done < "${DISTFEEDS}"

cp "${TMP_FEEDS}" "${DISTFEEDS}"
rm -f "${TMP_FEEDS}"

log "镜像源替换完成"

# ---- 3. 验证 ----
log "最终源配置："
grep -v '^#' "${DISTFEEDS}" | grep -v '^$' | while read -r line; do
    log "  ✅ ${line}"
done
grep '^\#.*disabled' "${DISTFEEDS}" | while read -r line; do
    log "  🚫 ${line}"
done

# ---- 4. 执行 apk update 并检查结果 ----
log "执行 apk update..."
if apk update 2>&1 | tail -1 | grep -q "OK"; then
    pkg_count=$(apk update 2>&1 | grep -o '[0-9]* distinct packages' | grep -o '[0-9]*')
    log "✅ 更新成功，可用包数: ${pkg_count}"
else
    log "⚠️ apk update 存在问题，请手动检查"
fi

log "APK 镜像源配置完成"