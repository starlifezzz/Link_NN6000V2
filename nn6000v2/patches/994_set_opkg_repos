#!/bin/sh
# 配置 opkg 软件源（使用浙江大学镜像）

#!/bin/sh
# 适配 ImmortalWrt 25.12+ (apk 版本) 的浙大镜像源替换脚本

# 1. 动态获取当前系统的版本号和架构
VERSION=$(grep 'DISTRIB_RELEASE=' /etc/openwrt_release | cut -d "'" -f 2)
ARCH=$(grep 'DISTRIB_ARCH=' /etc/openwrt_release | cut -d "'" -f 2)

# 如果获取失败，给个默认值保底 (假设你编译的是 25.12.0 或 SNAPSHOT)
VERSION=${VERSION:-"SNAPSHOT"}
ARCH=${ARCH:-"aarch64_cortex-a53"}

echo "当前系统版本: $VERSION"
echo "当前系统架构: $ARCH"

# 2. 判断是 SNAPSHOT 还是 正式版 (releases)
if [ "$VERSION" = "SNAPSHOT" ]; then
    REPO_TYPE="snapshots"
else
    REPO_TYPE="releases"
fi

# 浙大镜像站基础地址
MIRROR_BASE="https://mirrors.zju.edu.cn/immortalwrt/${REPO_TYPE}/${VERSION}"

# 3. 覆盖 apk 软件源列表 (注意路径变了！)
mkdir -p /etc/apk/repositories.d
cat > /etc/apk/repositories.d/distfeeds.list << EOF
${MIRROR_BASE}/packages/${ARCH}/base
${MIRROR_BASE}/packages/${ARCH}/luci
${MIRROR_BASE}/packages/${ARCH}/packages
${MIRROR_BASE}/packages/${ARCH}/routing
${MIRROR_BASE}/packages/${ARCH}/telephony
${MIRROR_BASE}/targets/qualcommax/ipq60xx/packages
EOF

echo "✓ APK 软件源已更新为浙江大学镜像站"

# 4. 更新软件包列表 (命令也变了！)
echo "正在更新软件包列表..."
apk update

if [ $? -eq 0 ]; then
    echo "✅ APK 软件源配置成功，浙大源连接正常！"
else
    echo "❌ 软件源更新失败，请检查网络连接或版本号 (${VERSION}) 是否正确。"
fi