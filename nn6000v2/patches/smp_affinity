#!/bin/sh /etc/rc.common
######################################################################
# vim: set ft=bash
# shellcheck disable=2155,3019,3043,3057,3060
######################################################################

START=93

PROG=smp_affinity

log_msg() {

    local irq_name="$1" affinity="$2" irq="$3"

    msg="$(printf "Pinning IRQ($irq) %-24s to CPU ${affinity}\n" "$irq_name")"

    logger -t "$PROG" "$msg"
}

######################################################################
### Takes a comma, space separated, or range list of CPU numbers and
## returns a bitmask of CPUs.
## cpus_to_bitmask "0,1,2,3" -> f
## cpus_to_bitmask "0 1 2 3" -> f
## cpus_to_bitmask "0-3"     -> f
## cpus_to_bitmask "3"       -> 8
#######################################################################

cpus_to_bitmask() {

    local bitmask=0
    # shellcheck disable=2048
    for range in ${*//,/ }; do
        start="${range%-*}"
        end="${range#*-}"
        if [ -z "$end" ]; then
            bitmask="$((bitmask | 1 << start))"
        else
            bitmask="$((bitmask | ((1 << (end - start + 1)) - 1) << start))"
        fi
    done
    printf '%x' $bitmask
}

######################################################################
### Takes a bitmask of CPUs and returns a space separated list of
## CPU numbers.
## bitmask_to_cpus f -> 0 1 2 3
######################################################################

bitmask_to_cpus() {

    [ "${1:0:2}" != "0x" ] && set -- "0x$1"
    local bitmask="$(printf '%d' "$1")"

    local cpus=""
    for i in $(seq 0 63); do
        if [ $((bitmask & 1)) -ne 0 ]; then
            cpus="$cpus $i"
        fi
        bitmask=$((bitmask >> 1))
    done
    echo "${cpus# }"
}

######################################################################
### Sets the affinity of the IRQs with the given name to the given CPU.
## 1st argument: IRQ name ("reo2host-destination-ring1") (req)
## 2nd argument: CPU number (req)
######################################################################

set_affinity() {
    local irq_name="$1" affinity="$2" occurrence="${3:-1}" bitmask irq
    awk -v irq_name="$1" -v occurrence="$occurrence" '
        BEGIN{count=0}
        $NF==irq_name {
            if(++count==occurrence){
                sub(/:$/,"",$1)
                print $1
            }
        }' /proc/interrupts | while read -r irq; do
        $enable_log && {
            log_msg "$irq_name" "$affinity" "$irq"
        }
        bitmask=$(cpus_to_bitmask "$affinity") && echo "$bitmask" >"/proc/irq/$irq/smp_affinity"
    done
}

# 检测 WiFi 是否存在（ath11k 驱动未加载则视为无 WiFi 版）
detect_wifi() {
    [ -d "/sys/kernel/debug/ieee80211/phy0" ] && return 0
    [ -d "/sys/kernel/debug/ieee80211/phy1" ] && return 0
    return 1
}

enable_affinity() {
    # 检测 CPU 核心数
    local cpu_count
    cpu_count=$(grep -c '^processor' /proc/cpuinfo 2>/dev/null || echo 4)
    
    local has_wifi=0
    detect_wifi && has_wifi=1 || logger -t "$PROG" "未检测到 WiFi 设备，使用纯有线网络优化策略"

    if [ "$cpu_count" -lt 4 ]; then
        # ---- 双核优化 ----
        logger -t "$PROG" "检测到 $cpu_count 核心 CPU，使用简化中断分配策略"

        # 以太网集中到 CPU0
        set_affinity 'edma_txcmpl' 0 1
        set_affinity 'edma_rxfill' 0 1
        set_affinity 'edma_rxdesc' 0 1
        set_affinity 'edma_misc' 0 1

        # NSS 硬件加速分配到 CPU0-1
        set_affinity 'nss_queue0' 0-1 1
        set_affinity 'bam_dma' 0 1

        if [ "$has_wifi" -eq 1 ]; then
            set_affinity 'reo2host-destination-ring1' 0 1
            set_affinity 'reo2host-destination-ring2' 0 1
            set_affinity 'reo2host-destination-ring3' 1 1
            set_affinity 'reo2host-destination-ring4' 1 1
            set_affinity 'wbm2host-tx-completions-ring1' 0 1
            set_affinity 'wbm2host-tx-completions-ring2' 1 1
            set_affinity 'wbm2host-tx-completions-ring3' 1 1
        fi
    else
        # ---- 四核优化 ----
        logger -t "$PROG" "检测到 $cpu_count 核心 CPU"

        if [ "$has_wifi" -eq 1 ]; then
            # 有 WiFi：WiFi + 网络混合调度，避免干扰
            logger -t "$PROG" "使用 WiFi+有线混合中断分配策略"

            set_affinity 'reo2host-destination-ring1' 0 1
            set_affinity 'reo2host-destination-ring2' 1 1
            set_affinity 'reo2host-destination-ring3' 2 1
            set_affinity 'reo2host-destination-ring4' 3 1

            set_affinity 'wbm2host-tx-completions-ring1' 1 1
            set_affinity 'wbm2host-tx-completions-ring2' 2 1
            set_affinity 'wbm2host-tx-completions-ring3' 3 1

            set_affinity 'ppdu-end-interrupts-mac1' 1 1
            set_affinity 'ppdu-end-interrupts-mac2' 2 1
            set_affinity 'ppdu-end-interrupts-mac3' 3 1

            # 以太网集中到 CPU3（避免干扰 WiFi 所在的 0-2 核）
            set_affinity 'edma_txcmpl' 3 1
            set_affinity 'edma_rxfill' 3 1
            set_affinity 'edma_rxdesc' 3 1
            set_affinity 'edma_misc' 3 1

            set_affinity 'nss_queue0' 2-3 1
        else
            # 无 WiFi：所有中断均匀分散，最大化吞吐
            logger -t "$PROG" "使用纯有线性能优化中断分配策略"

            # 以太网分散到所有 4 核
            set_affinity 'edma_txcmpl' 0-1 1
            set_affinity 'edma_rxfill' 3 1
            set_affinity 'edma_rxdesc' 2 1
            set_affinity 'edma_misc' 2-3 1

            # NSS 硬件加速利用全部核心
            set_affinity 'nss_queue0' 0-3 1
        fi

        # DMA 引擎分散到 CPU1-3
        set_affinity 'bam_dma' 1 1
        set_affinity 'bam_dma' 2 2
        set_affinity 'bam_dma' 3 3
    fi

    # 设置默认中断亲和性为所有核心
    if [ -f /proc/irq/default_smp_affinity ]; then
        echo "f" > /proc/irq/default_smp_affinity 2>/dev/null || true
    fi
}

boot() {

    local enable

    config_load smp_affinity

    config_get_bool enable "general" enable 1
    config_get_bool enable_log "general" enable_log 1

    [ "$enable" -eq 1 ] && enable=true || enable=false
    [ "$enable_log" -eq 1 ] && enable_log=true || enable_log=false

    $enable && enable_affinity
}
